# Block execution of PHP files in uploads directory
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|pht|phps|phar)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Force plain text for any script files
AddType text/plain .php .phtml .php3 .php4 .php5 .php7 .pht .phps .phar
