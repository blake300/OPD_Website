Options -Indexes


<IfModule mod_dir.c>
  DirectoryIndex index.php index.html
</IfModule>

# URL Rewriting for custom pages
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Custom pages: /page/slug -> page.php?slug=slug
  RewriteRule ^page/([a-z0-9-]+)/?$ page.php?slug=$1 [L,QSA]
</IfModule>

<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
